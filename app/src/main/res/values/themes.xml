<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.NotesApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryVariant</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        
        <!-- Secondary Colors -->
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorSecondaryVariant">@color/colorSecondaryVariant</item>
        <item name="colorOnSecondary">@color/colorOnSecondary</item>
        
        <!-- Surface Colors -->
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>
        
        <!-- Background Colors -->
        <item name="android:colorBackground">@color/colorBackground</item>
        
        <!-- Error Colors -->
        <item name="colorError">@color/colorError</item>
        
        <!-- Status Bar and Navigation Bar -->
        <item name="android:statusBarColor">@color/colorSurfaceVariant</item>
        <item name="android:navigationBarColor">@color/colorSurfaceVariant</item>
        
        <!-- Bottom Navigation Colors -->
        <item name="bottomNavBackgroundColor">#E6F5F5F5</item>
        <item name="bottomNavStrokeColor">#33000000</item>
        
        <!-- Text Colors -->
        <item name="android:textColorPrimary">@color/colorTextPrimary</item>
        <item name="android:textColorSecondary">@color/colorTextSecondary</item>
        
        <!-- Window Flags -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <!-- Custom Alert Dialog Theme -->
    <style name="CustomAlertDialogTheme" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowMinWidthMajor">80%</item>
        <item name="android:windowMinWidthMinor">80%</item>
    </style>

    <style name="CustomAlertDialog" parent="@android:style/Theme.Dialog">
        <item name="android:background">@color/colorSurface</item>
    </style>

</resources>
